{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
  ],
  platformAutomerge: true,
  rebaseWhen: 'never',
  customManagers: [
    {
      // Matches inline `# renovate: datasource=... depName=...` annotations in build.sh.
      // Uses github-releases (not github-release-attachments) because the RPM asset filenames
      // embed the version, making digest computation impossible for github-release-attachments.
      // SHA256 variables in the script must be updated manually when the version changes.
      // The generic [A-Z_]+_VERSION pattern is intentional: only lines immediately preceded
      // by a valid `# renovate:` annotation comment will be matched, so false positives
      // are not possible; it also makes this manager reusable for future annotated packages.
      customType: 'regex',
      managerFilePatterns: [
        '/^build_files/build\\.sh$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)[^\\n]*\\n[A-Z_]+_VERSION="(?<currentValue>[^"]+)"',
      ],
      versioningTemplate: 'loose',
    },
  ],
  packageRules: [
    {
      matchDatasources: [
        'github-releases',
      ],
      matchPackageNames: [
        'realmcuser/cockpit-nspawn',
      ],
      // Upstream started publishing tags like `cockpit-nspawn-v1.0.0-70`;
      // normalize both prefixed and plain tags to keep updates flowing.
      extractVersion: '^(?:cockpit-nspawn-)?(?<version>v\\d+\\.\\d+\\.\\d+-\\d+)$',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ghcr.io/ublue-os/bazzite-dx',
      ],
      automerge: true,
    },
  ],
}
